<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:FunctionApproximator.UI.Controls"
                    x:Class="FunctionApproximator.UI.Themes.Styles">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="../Controls/ScrollBar/ScrollBar.xaml"/>
        <ResourceDictionary Source="../Controls/GroupBox/GroupBox.xaml"/>
        <ResourceDictionary Source="/FunctionApproximator.UI;component/Themes/Colors.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="Styles.TextBlock" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Foreground" Value="{StaticResource Gray900Brush}"/>
    </Style>

    <Style TargetType="TextBlock" BasedOn="{StaticResource Styles.TextBlock}"/>

    <Style x:Key="Styles.TextBox" TargetType="TextBox">
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="15"/>
    </Style>

    <Style TargetType="TextBox" BasedOn="{StaticResource Styles.TextBox}"/>

    <Style x:Key="Styles.Buttons.Iconic" TargetType="controls:NormalButton">

        <Setter Property="Background" Value="{StaticResource Gray200Brush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Padding" Value="2"/>

        <Setter Property="Validation.ErrorTemplate" Value="{x:Null}"/>

        <Style.Triggers>

            <Trigger Property="IsMouseOver" Value="True">

                <Setter Property="BorderBrush" Value="{StaticResource Gray700Brush}"/>
                <Setter Property="Background" Value="{StaticResource Gray400Brush}"/>

            </Trigger>

        </Style.Triggers>

    </Style>

    <Style x:Key="Styles.Separator.Horizontal" TargetType="Rectangle">
        <Setter Property="Fill" Value="{StaticResource Gray700Brush}"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Height" Value="3"/>
    </Style>

    <Style x:Key="Styles.Separator.Vertical" TargetType="Rectangle">
        <Setter Property="Fill" Value="{StaticResource Gray700Brush}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="Width" Value="3"/>
    </Style>

    <Style x:Key="Styles.ScrollBar" TargetType="ScrollBar"
       BasedOn="{StaticResource Styles.ScrollBar.Base}">
        <Setter Property="Foreground" Value="{StaticResource Gray400Brush}"/>
    </Style>

    <Style x:Key="Styles.ScrollViewer" TargetType="ScrollViewer">
        <Style.Resources>

            <Style TargetType="ScrollBar" BasedOn="{StaticResource Styles.ScrollBar}"/>

        </Style.Resources>
    </Style>

    <Style x:Key="Styles.AdvancedTextBox" TargetType="controls:AdvancedTextBox">

        <Style.Resources>
            <Style TargetType="ScrollBar" BasedOn="{StaticResource Styles.ScrollBar}"/>
        </Style.Resources>

        <Setter Property="Background" Value="{StaticResource Gray500Brush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="BorderBrush" Value="{StaticResource Gray400Brush}"/>
        <Setter Property="Foreground" Value="{StaticResource Gray900Brush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource Gray700Brush}"/>
        <Setter Property="PlaceholderBrush" Value="{StaticResource Gray400Brush}"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Padding" Value="8 2 8 2"/>

        <EventSetter Event="PreviewMouseDown" Handler="TextBox_PreviewMouseDown"/>
        <EventSetter Event="GotKeyboardFocus" Handler="TextBox_GotKeyboardFocus"/>
    </Style>

    <Style TargetType="controls:AdvancedTextBox" BasedOn="{StaticResource Styles.AdvancedTextBox}"/>

    <Style x:Key="Styles.ComboBox" TargetType="controls:AdvancedComboBox">

        <Setter Property="Background" Value="{StaticResource Gray500Brush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="BorderBrush" Value="{StaticResource Gray400Brush}"/>
        <Setter Property="Foreground" Value="{StaticResource Gray900Brush}"/>
        <Setter Property="ItemMouseOverBrush" Value="{StaticResource Gray600Brush}"/>
        <Setter Property="ItemSelectedBrush" Value="{StaticResource Gray650Brush}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="16"/>

    </Style>

    <Style TargetType="ComboBox" BasedOn="{StaticResource Styles.ComboBox}"/>

    <Style x:Key="Styles.GroupBox" TargetType="GroupBox"
           BasedOn="{StaticResource Styles.GroupBox.Base}">
        <Setter Property="Padding" Value="10"/>
        <Setter Property="BorderBrush" Value="{StaticResource Gray400Brush}"/>
        <Setter Property="BorderThickness" Value="2"/>

    </Style>

    <Style TargetType="GroupBox" BasedOn="{StaticResource Styles.GroupBox}"/>

    <Style x:Key="Styles.Buttons.Color" TargetType="Button">

        <Setter Property="Template">
            <Setter.Value>

                <ControlTemplate TargetType="Button">

                    <Border Background="{TemplateBinding Foreground}"
                            MinHeight="{TemplateBinding MinHeight}"
                            MinWidth="{TemplateBinding MinHeight}"
                            MaxHeight="{TemplateBinding MaxHeight}"
                            MaxWidth="{TemplateBinding MinHeight}"
                            Padding="2">

                        <Border Background="{TemplateBinding Background}"
                                VerticalAlignment="Stretch"
                                HorizontalAlignment="Stretch"/>

                    </Border>
                    
                </ControlTemplate>
                
            </Setter.Value>
        </Setter>

        <Setter Property="MinHeight" Value="20"/>
        <Setter Property="MinWidth" Value="20"/>
        <Setter Property="Foreground" Value="{StaticResource Gray900Brush}"/>

    </Style>
    
</ResourceDictionary>