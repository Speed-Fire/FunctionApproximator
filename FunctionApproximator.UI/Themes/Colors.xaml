<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="Gray200">#1E1E1E</Color>
    <Color x:Key="Gray300">#333333</Color>
    <Color x:Key="Gray400">#3D3D3D</Color>
    <Color x:Key="Gray500">#4f4f4f</Color>
    <Color x:Key="Gray600">#6f6f6f</Color>
    <Color x:Key="Gray650">#8f8f8f</Color>
    <Color x:Key="Gray700">#C6C6C6</Color>
    <Color x:Key="Gray900">#F8E9FE</Color>

    <Color x:Key="DarkestVio;et">#32004D</Color>

    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}" x:Shared="True"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}" x:Shared="True"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}" x:Shared="True"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}" x:Shared="True"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}" x:Shared="True"/>
    <SolidColorBrush x:Key="Gray650Brush" Color="{StaticResource Gray650}" x:Shared="True"/>
    <SolidColorBrush x:Key="Gray700Brush" Color="{StaticResource Gray700}" x:Shared="True"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}" x:Shared="True"/>
    <SolidColorBrush x:Key="DarkestVioletBrush" Color="{StaticResource DarkestVio;et}" x:Shared="True"/>

    

</ResourceDictionary>