<Window x:Class="FunctionApproximator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FunctionApproximator"
        
        xmlns:decorators="clr-namespace:FunctionApproximator.UI.Decorators;assembly=FunctionApproximator.UI"
        xmlns:views="clr-namespace:FunctionApproximator.Views"
        
        WindowStyle="None"
        AllowsTransparency="True"
        
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <decorators:DpiDecorator>
        <views:MainView DataContext="{Binding}"/>
    </decorators:DpiDecorator>
    
    
</Window>
