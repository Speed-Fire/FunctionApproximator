<UserControl x:Class="FunctionApproximator.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FunctionApproximator.Views"
             
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:comps="clr-namespace:FunctionApproximator.Components"
             xmlns:convs="clr-namespace:FunctionApproximator.UI.Converters;assembly=FunctionApproximator.UI"

             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>

        <convs:BooleanToVisibilityConverter x:Key="b2vconv"/>

        <Style TargetType="{x:Type oxy:TrackerControl}">
            <Setter Property="Background" Value="#222222"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="LineStroke" Value="White"/>
        </Style>

    </UserControl.Resources>

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadedCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid Background="{StaticResource Gray200Brush}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <comps:WindowHeaderComponent Grid.Row="0"/>

        <Grid Grid.Row="1" Margin="5">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>


            <comps:ManagementComponent
                Grid.Row="0"
                DataContext="{Binding}"/>

            <oxy:PlotView 
                Grid.Row="0" Grid.Column="1" Background="Transparent"
                
                Model="{Binding GraphPlotter.Model}">

                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="PreviewMouseUp">
                        <i:InvokeCommandAction Command="{Binding GraphPlotter.MouseUpCommand}"
                                               PassEventArgsToCommand="True"/>
                    </i:EventTrigger>
                </i:Interaction.Triggers>
            </oxy:PlotView>

            <comps:NotificationsComponent
                Grid.Row="1"/>

            <Grid Grid.Row="1" Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.49*"/>
                    <ColumnDefinition Width="0.02*"/>
                    <ColumnDefinition Width="0.49*"/>
                </Grid.ColumnDefinitions>

                <comps:ApproximatorComponent DataContext="{Binding}"/>

                <comps:DrawingSettingsComponents Grid.Column="2"
                                                 DataContext="{Binding DrawingSettings}"/>

            </Grid>

        </Grid>

    </Grid>
</UserControl>
