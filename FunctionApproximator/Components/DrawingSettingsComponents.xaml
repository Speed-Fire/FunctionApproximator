<UserControl x:Class="FunctionApproximator.Components.DrawingSettingsComponents"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FunctionApproximator.Components"
             xmlns:controls="clr-namespace:FunctionApproximator.UI.Controls;assembly=FunctionApproximator.UI"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>

        <Style TargetType="CheckBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="Local.Styles.Buttons.Color" TargetType="Button"
               BasedOn="{StaticResource Styles.Buttons.Color}">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Margin" Value="15 0 0 0"/>
        </Style>
        
    </UserControl.Resources>
    
    <GroupBox Header="Appearance"
          Padding="10">

        <Grid Grid.IsSharedSizeScope="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="6"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="3"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="15"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="6"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="3"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Drawing step"/>

            <RadioButton Grid.Row="2"
                         GroupName="StepMode"
                         IsChecked="{Binding IsAutoDrawingStep}"
                         VerticalContentAlignment="Center"
                         Content="Automatic"/>

            <RadioButton x:Name="ManualStepRB"
                         Grid.Row="4"
                         GroupName="StepMode"
                         VerticalContentAlignment="Center"
                         HorizontalContentAlignment="Stretch">
                <StackPanel Orientation="Horizontal">

                    <TextBlock Text="Manual:"
                               VerticalAlignment="Center"
                               Margin="0 0 5 0"/>

                    <controls:AdvancedTextBox Text="{Binding DrawingStep}">
                        <controls:AdvancedTextBox.Style>
                            <Style TargetType="controls:AdvancedTextBox"
                                   BasedOn="{StaticResource Styles.AdvancedTextBox}">
                                <Setter Property="IsEnabled" Value="False"/>
                                <Setter Property="MinWidth" Value="30"/>
                                <Style.Triggers>

                                    <DataTrigger Binding="{Binding ElementName=ManualStepRB,
                                        Path=IsChecked}" Value="True">
                                        <Setter Property="IsEnabled" Value="True"/>
                                    </DataTrigger>
                                    
                                </Style.Triggers>
                            </Style>
                        </controls:AdvancedTextBox.Style>
                    </controls:AdvancedTextBox>

                </StackPanel>
            </RadioButton>

            <TextBlock Grid.Column="1"
                       Text="Graph appearance"/>

            <CheckBox Grid.Row="2" Grid.Column="1"
                      IsChecked="{Binding ShowApproximatedGraph}"
                      VerticalContentAlignment="Center"
                      Content="Show approximated fraph"/>

            <CheckBox Grid.Row="4" Grid.Column="1"
                      IsChecked="{Binding ShowInputGraph}"
                      VerticalContentAlignment="Center"
                      Content="Show input values graph"/>

            <TextBlock Grid.Row="6" Grid.Column="1"
                       Text="Colors"/>

            <Grid Grid.Row="8" Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Col1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Approximated graph:"/>

                <Button Grid.Column="1"
                        Style="{StaticResource Local.Styles.Buttons.Color}"
                        Background="{Binding ApproximatedGraphColor, Mode=TwoWay}"
                        Click="ChangeApproximatedGraphColor"/>

            </Grid>

            <Grid Grid.Row="10" Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Col1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Input values:"/>

                <Button Grid.Column="1"
                        Style="{StaticResource Local.Styles.Buttons.Color}"
                        Background="{Binding InputGraphColor, Mode=TwoWay}"
                        Click="ChangeInputGraphColor"/>

            </Grid>

            <TextBlock Grid.Row="6" Grid.Column="0"
                       Text="Gridlines"/>

            <CheckBox Grid.Row="8" Grid.Column="0"
                      IsChecked="{Binding ShowMajorGridlines}"
                      Content="Show major gridlines"/>

            <CheckBox Grid.Row="10" Grid.Column="0"
                      IsChecked="{Binding ShowMinorGridlines}"
                      Content="Show minor gridlines"/>

        </Grid>
        
    </GroupBox>
    
</UserControl>
