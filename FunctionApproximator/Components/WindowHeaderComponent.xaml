<UserControl x:Class="FunctionApproximator.Components.WindowHeaderComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FunctionApproximator.Components"
             xmlns:controls="clr-namespace:FunctionApproximator.UI.Controls;assembly=FunctionApproximator.UI"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>

        <Path x:Key="Local.Paths.Cross"
              Data="M 0,0 14,14 M 14,0 0,14"
              Stroke="{StaticResource Gray700Brush}"/>

        <Path x:Key="Local.Paths.Hide"
              Data="M 0,1 14,1"
              Stroke="{StaticResource Gray700Brush}"/>

        <Path x:Key="Local.Paths.Expand"
              Data="M 2,2 0,2 0,14 12,14 12,12 14,12 14,0 2,0 2,2 12,2 12,12"
              Stroke="{StaticResource Gray700Brush}"/>

        <Style x:Key="Local.Styles.Buttons.Header" TargetType="controls:NormalButton">

            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15 5 15 5"/>
            <Setter Property="Background" Value="{StaticResource Gray200Brush}"/>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Gray400Brush}"/>
                </Trigger>
            </Style.Triggers>
            
        </Style>

        <Style x:Key="Local.Styles.Buttons.Close" TargetType="controls:NormalButton">

            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15 5 15 5"/>
            <Setter Property="Background" Value="#D50000"/>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF5151"/>
                </Trigger>
            </Style.Triggers>

        </Style>

    </UserControl.Resources>
    
    <Grid Background="{StaticResource Gray200Brush}"
          MinHeight="32"
          MouseMove="UserControl_MouseMove">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Image Source="{StaticResource Bitmaps.App32}" Height="32"/>

        <TextBlock Grid.Column="1"
                   FontSize="18"
                   Margin="5 0 0 0"
                   VerticalAlignment="Center"
                   Text="Approximator"/>

        <controls:NormalButton 
            Grid.Column="3"
            Style="{StaticResource Local.Styles.Buttons.Header}"
            Content="{StaticResource Local.Paths.Hide}"
            Click="HideButton_Click"/>
        
        <controls:NormalButton 
            Grid.Column="4"
            Style="{StaticResource Local.Styles.Buttons.Header}"
            Content="{StaticResource Local.Paths.Expand}"
            Click="ExpandButton_Click"/>
        
        <controls:NormalButton 
            Grid.Column="5"
            Style="{StaticResource Local.Styles.Buttons.Close}"
            Content="{StaticResource Local.Paths.Cross}"
            Click="CloseButton_Click"/>

    </Grid>
    
</UserControl>
