<UserControl x:Class="FunctionApproximator.Components.ManagementComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FunctionApproximator.Components"
             xmlns:controls="clr-namespace:FunctionApproximator.UI.Controls;assembly=FunctionApproximator.UI"
             xmlns:root="clr-namespace:FunctionApproximator"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>

        <Style TargetType="TextBlock" BasedOn="{StaticResource Styles.TextBlock}">
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="Local.Styles.ListBoxItem" TargetType="ListBoxItem">

            <Setter Property="Padding" Value="0 5 0 5"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">

                        <Border x:Name="Border"
                    Padding="2 10 2 10"
                    SnapsToDevicePixels="true"
                    Background="Transparent">

                            <ContentPresenter
                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>

                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

        </Style>

        <DataTemplate x:Key="Local.Templates.ListBoxItem.Point">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.15*"/>
                    <ColumnDefinition Width="0.35*"/>
                    <ColumnDefinition Width="0.35*"/>
                    <ColumnDefinition Width="0.15*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding Id}"
                           VerticalAlignment="Center"
                           Margin="5 0 0 0"/>

                <controls:AdvancedTextBox Grid.Column="1"
                         Margin="2 0 2 0"
                         Text="{Binding X, UpdateSourceTrigger=PropertyChanged}"/>

                <controls:AdvancedTextBox Grid.Column="2"
                         Margin="2 0 2 0"
                         Text="{Binding Y, UpdateSourceTrigger=PropertyChanged}"/>

                <controls:NormalButton 
                    Grid.Column="3"
                    Style="{StaticResource Styles.Buttons.Iconic}"               
                    Command="{Binding RelativeSource={RelativeSource Mode=FindAncestor,
                        AncestorType=local:ManagementComponent},
                        Path=DataContext.PointData.DeletePointCommand}"
                    CommandParameter="{Binding}">
                    <Image Source="{StaticResource Bitmaps.Delete24}" Width="24"/>
                </controls:NormalButton>

            </Grid>

        </DataTemplate>

        <Style x:Key="Local.Styles.ListBox" TargetType="ListBox">

            <Style.Resources>
                <Style TargetType="ScrollViewer" BasedOn="{StaticResource Styles.ScrollViewer}"/>
            </Style.Resources>

            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel"/>
        </Style>

        <Style x:Key="Local.Styles.Border" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource Gray400Brush}"/>
            <Setter Property="BorderThickness" Value="3"/>
        </Style>

        <ControlTemplate x:Key="Local.Templates.TabControl" TargetType="TabControl">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TabPanel Grid.Row="0"
                          IsItemsHost="True"/>

                <ContentPresenter Grid.Row="1"
                                  ContentSource="SelectedContent"/>
            </Grid>
        </ControlTemplate>

        <ControlTemplate x:Key="Local.Templates.TabItem" TargetType="TabItem">
            <Border x:Name="Bd"
                        Padding="10 4 10 4"
                        Background="{TemplateBinding Background}">
                <ContentPresenter ContentSource="Header"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
            </Border>

        </ControlTemplate>

        <Style x:Key="Local.Styles.TabItem" TargetType="TabItem">
            <Setter Property="Template" Value="{StaticResource Local.Templates.TabItem}"/>
            <Setter Property="Background" Value="{StaticResource Gray400Brush}"/>

            <Style.Triggers>

                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Gray700Brush}"/>
                </Trigger>

                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource Gray600Brush}"/>
                </Trigger>
                
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="Local.Templates.ListBoxItem.Coefficient">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.15*"/>
                    <ColumnDefinition Width="0.35*"/>
                    <ColumnDefinition Width="0.35*"/>
                    <ColumnDefinition Width="0.15*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding 
                    RelativeSource={RelativeSource AncestorType=ListBoxItem},
                    Path=(ItemsControl.AlternationIndex)}"
                           VerticalAlignment="Center"
                           Margin="5 0 0 0"/>

                <controls:AdvancedTextBox 
                           Grid.Column="1"
                           Grid.ColumnSpan="2"
                           Margin="2 0 2 0"
                           IsReadOnly="True"
                           Text="{Binding Path=., Mode=OneWay}">
                    <controls:AdvancedTextBox.ToolTip>
                        <TextBlock Text="{Binding Path=., Mode=OneWay}"
                                   Foreground="Black"/>
                    </controls:AdvancedTextBox.ToolTip>
                </controls:AdvancedTextBox>

                <controls:NormalButton 
                           Grid.Column="3"
                           Style="{StaticResource Styles.Buttons.Iconic}"
                           Command="{Binding
                        RelativeSource={RelativeSource AncestorType=ListBox},
                        Path=DataContext.CopyToClipboardCommand}"
                           CommandParameter="{Binding}">
                    <Image Source="{StaticResource Bitmaps.Copy24}" Width="24"/>
                </controls:NormalButton>

            </Grid>

        </DataTemplate>

    </UserControl.Resources>

    <Grid>

        <TabControl Template="{StaticResource Local.Templates.TabControl}">
            <TabItem Header="Points" Style="{StaticResource Local.Styles.TabItem}">

                <Grid Background="{StaticResource Gray200Brush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <controls:NormalButton
                            Grid.Column="0"
                            Style="{StaticResource Styles.Buttons.Iconic}"
                            Command="{Binding FileLoader.LoadFileCommand}">
                            <Image Source="{StaticResource Bitmaps.OpenFolder24}" Width="24"/>
                            <controls:NormalButton.ToolTip>
                                <TextBlock Foreground="Black" Text="Open file"/>
                            </controls:NormalButton.ToolTip>
                        </controls:NormalButton>

                        <controls:NormalButton
                            Grid.Column="1"
                            Style="{StaticResource Styles.Buttons.Iconic}"
                            Command="{Binding PointData.CreatePointCommand}">
                            <Image Source="{StaticResource Bitmaps.Add24}" Width="24"/>
                            <controls:NormalButton.ToolTip>
                                <TextBlock Foreground="Black" Text="Add point"/>
                            </controls:NormalButton.ToolTip>
                        </controls:NormalButton>

                        <controls:NormalButton
                            Grid.Column="2"
                            Style="{StaticResource Styles.Buttons.Iconic}"
                            Command="{Binding PointData.ClearPointsCommand}">
                            <Image Source="{StaticResource Bitmaps.Bin24}" Width="24"/>
                            <controls:NormalButton.ToolTip>
                                <TextBlock Foreground="Black" Text="Delete all points"/>
                            </controls:NormalButton.ToolTip>
                        </controls:NormalButton>

                        <!--<controls:NormalButton
                            Grid.Column="4"
                            Style="{StaticResource Styles.Buttons.Iconic}"
                            Command="{Binding PlotGraphCommand}">
                            <Image Source="{StaticResource Bitmaps.Graph24}" Width="24"/>
                            <controls:NormalButton.ToolTip>
                                <TextBlock Foreground="Black" Text="Plot graphs"/>
                            </controls:NormalButton.ToolTip>
                        </controls:NormalButton>

                        <controls:NormalButton
                            Grid.Column="5"
                            Style="{StaticResource Styles.Buttons.Iconic}"
                            Command="{Binding ClearGraphCommand}">
                            <Image Source="{StaticResource Bitmaps.Eraser24}" Width="24"/>
                            <controls:NormalButton.ToolTip>
                                <TextBlock Foreground="Black" Text="Erase graphs"/>
                            </controls:NormalButton.ToolTip>
                        </controls:NormalButton>-->

                    </Grid>

                    <Border Grid.Row="1"
                        Style="{StaticResource Local.Styles.Border}">

                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource Local.Styles.Border}"
                                Margin="-3 -3 -3 0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.2*"/>
                                        <ColumnDefinition Width="0.35*"/>
                                        <ColumnDefinition Width="0.35*"/>
                                        <ColumnDefinition Width="0.1*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="#"/>

                                    <TextBlock Grid.Column="1"
                                           Text="X"/>

                                    <TextBlock Grid.Column="2"
                                           Text="Y"/>
                                </Grid>
                            </Border>

                            <ListBox Grid.Row="1"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 Style="{StaticResource Local.Styles.ListBox}"
                                 ItemContainerStyle="{StaticResource Local.Styles.ListBoxItem}"
                                 ItemTemplate="{StaticResource Local.Templates.ListBoxItem.Point}"
                                 ItemsSource="{Binding PointData.Points}"/>

                        </Grid>
                    </Border>

                </Grid>

            </TabItem>

            <TabItem Header="Coefficients" Style="{StaticResource Local.Styles.TabItem}">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <controls:NormalButton
                        Style="{StaticResource Styles.Buttons.Iconic}"
                        Visibility="Hidden">
                        <Image Source="{StaticResource Bitmaps.OpenFolder24}" Width="24"/>
                    </controls:NormalButton>

                    <Border Grid.Row="1"
                            Style="{StaticResource Local.Styles.Border}">

                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Style="{StaticResource Local.Styles.Border}"
                                    Margin="-3 -3 -3 0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.2*"/>
                                        <ColumnDefinition Width="0.35*"/>
                                        <ColumnDefinition Width="0.35*"/>
                                        <ColumnDefinition Width="0.1*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="#"/>

                                    <TextBlock Grid.Column="1" Grid.ColumnSpan="2"
                                               Text="a"/>

                                </Grid>
                            </Border>

                            <ListBox Grid.Row="1" AlternationCount="10000"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     Style="{StaticResource Local.Styles.ListBox}"
                                     ItemContainerStyle="{StaticResource Local.Styles.ListBoxItem}"
                                     ItemTemplate="{StaticResource Local.Templates.ListBoxItem.Coefficient}"
                                     ItemsSource="{Binding Approximator.Coefficients}"/>

                        </Grid>
                    </Border>

                </Grid>
                
            </TabItem>

        </TabControl>

        <Grid VerticalAlignment="Top"
              Margin="0 30 0 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <controls:NormalButton
                    Grid.Column="1"
                    Style="{StaticResource Styles.Buttons.Iconic}"
                    Command="{Binding PlotGraphCommand}">
                <Image Source="{StaticResource Bitmaps.Graph24}" Width="24"/>
                <controls:NormalButton.ToolTip>
                    <TextBlock Foreground="Black" Text="Plot graphs"/>
                </controls:NormalButton.ToolTip>
            </controls:NormalButton>

            <controls:NormalButton
                    Grid.Column="2"
                    Style="{StaticResource Styles.Buttons.Iconic}"
                    Command="{Binding ClearGraphCommand}">
                <Image Source="{StaticResource Bitmaps.Eraser24}" Width="24"/>
                <controls:NormalButton.ToolTip>
                    <TextBlock Foreground="Black" Text="Erase graphs"/>
                </controls:NormalButton.ToolTip>
            </controls:NormalButton>

        </Grid>
        
    </Grid>

</UserControl>
