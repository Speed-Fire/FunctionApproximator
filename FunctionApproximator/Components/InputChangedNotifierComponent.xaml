<UserControl x:Class="FunctionApproximator.Components.InputChangedNotifierComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FunctionApproximator.Components"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Image Source="{StaticResource Bitmaps.LightOff32}" Width="32"/>

        <Image x:Name="LightBulb"
               Source="{StaticResource Bitmaps.LightOn32}" Width="32"/>

        <TextBlock Grid.Column="1" x:Name="AttentionText"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap"
                   Margin="10 0 0 0"
                   Text="Attention! Input data was changed. Please replot the graph."/>

        <Image Grid.Row="2"
               Source="{StaticResource Bitmaps.LightOff32}" Width="32"/>

        <Image x:Name="ErrorLightBulb" Grid.Row="2"
               Source="{StaticResource Bitmaps.LightOn32}" Width="32"/>

        <TextBlock Grid.Column="1" Grid.Row="2" x:Name="ErrorText"
                   Foreground="Red"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap"
                   Margin="10 0 0 0"/>

    </Grid>
</UserControl>
