<UserControl x:Class="FunctionApproximator.Components.PointsInputComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FunctionApproximator.Components"
             xmlns:controls="clr-namespace:FunctionApproximator.UI.Controls;assembly=FunctionApproximator.UI"
             xmlns:root="clr-namespace:FunctionApproximator"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>

        <Style TargetType="TextBlock" BasedOn="{StaticResource Styles.TextBlock}">
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="Local.Styles.ListBoxItem" TargetType="ListBoxItem">

            <Setter Property="Padding" Value="0 5 0 5"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">

                        <Border x:Name="Border"
                    Padding="2 10 2 10"
                    SnapsToDevicePixels="true"
                    Background="Transparent">

                            <ContentPresenter
                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>

                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

        </Style>

        <DataTemplate x:Key="Local.Templates.ListBoxItem">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.15*"/>
                    <ColumnDefinition Width="0.35*"/>
                    <ColumnDefinition Width="0.35*"/>
                    <ColumnDefinition Width="0.15*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding Id}"
                           VerticalAlignment="Center"
                           Margin="5 0 0 0"/>

                <controls:AdvancedTextBox Grid.Column="1"
                         Margin="2 0 2 0"
                         Text="{Binding X, UpdateSourceTrigger=PropertyChanged}"/>

                <controls:AdvancedTextBox Grid.Column="2"
                         Margin="2 0 2 0"
                         Text="{Binding Y, UpdateSourceTrigger=PropertyChanged}"/>

                <controls:NormalButton 
                    Grid.Column="3"
                    Style="{StaticResource Styles.Buttons.Iconic}"               
                    Command="{Binding RelativeSource={RelativeSource Mode=FindAncestor,
                        AncestorType=local:PointsInputComponent},
                        Path=DataContext.DeletePointCommand}"
                    CommandParameter="{Binding}">
                    <Image Source="{StaticResource Bitmaps.Delete24}" Width="24"/>
                </controls:NormalButton>

            </Grid>

        </DataTemplate>

        <Style x:Key="Local.Styles.ListBox" TargetType="ListBox">

            <Style.Resources>
                <Style TargetType="ScrollViewer" BasedOn="{StaticResource Styles.ScrollViewer}"/>
            </Style.Resources>

            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel"/>
        </Style>

        <Style x:Key="Local.Styles.Border" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource Gray400Brush}"/>
            <Setter Property="BorderThickness" Value="3"/>
        </Style>

    </UserControl.Resources>
    
    <Grid Background="{StaticResource Gray200Brush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Points"
                   HorizontalAlignment="Left"/>
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <controls:NormalButton
                Grid.Column="0"
                Style="{StaticResource Styles.Buttons.Iconic}"
                Command="{Binding LoadFileCommand}">
                <Image Source="{StaticResource Bitmaps.OpenFolder24}" Width="24"/>
                <controls:NormalButton.ToolTip><TextBlock Foreground="Black" Text="Open file"/></controls:NormalButton.ToolTip>
            </controls:NormalButton>

            <controls:NormalButton
                Grid.Column="1"
                Style="{StaticResource Styles.Buttons.Iconic}"
                Command="{Binding CreatePointCommand}">
                <Image Source="{StaticResource Bitmaps.Add24}" Width="24"/>
                <controls:NormalButton.ToolTip><TextBlock Foreground="Black" Text="Add point"/></controls:NormalButton.ToolTip>
            </controls:NormalButton>

            <controls:NormalButton
                Grid.Column="2"
                Style="{StaticResource Styles.Buttons.Iconic}"
                Command="{Binding ClearPointsCommand}">
                <Image Source="{StaticResource Bitmaps.Bin24}" Width="24"/>
                <controls:NormalButton.ToolTip><TextBlock Foreground="Black" Text="Delete all points"/></controls:NormalButton.ToolTip>
            </controls:NormalButton>

            <controls:NormalButton
                Grid.Column="4"
                Style="{StaticResource Styles.Buttons.Iconic}"
                Command="{Binding RelativeSource={RelativeSource Mode=FindAncestor,
                    AncestorType={x:Type root:MainWindow}}, Path=DataContext.PlotGraphCommand}">
                <Image Source="{StaticResource Bitmaps.Graph24}" Width="24"/>
                <controls:NormalButton.ToolTip><TextBlock Foreground="Black" Text="Plot graphs"/></controls:NormalButton.ToolTip>
            </controls:NormalButton>

            <controls:NormalButton
                Grid.Column="5"
                Style="{StaticResource Styles.Buttons.Iconic}"
                Command="{Binding RelativeSource={RelativeSource Mode=FindAncestor,
                    AncestorType={x:Type root:MainWindow}}, Path=DataContext.ClearGraphCommand}">
                <Image Source="{StaticResource Bitmaps.Eraser24}" Width="24"/>
                <controls:NormalButton.ToolTip><TextBlock Foreground="Black" Text="Erase graphs"/></controls:NormalButton.ToolTip>
            </controls:NormalButton>

        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource Local.Styles.Border}">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Style="{StaticResource Local.Styles.Border}"
                        Margin="-3 -3 -3 0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.2*"/>
                            <ColumnDefinition Width="0.35*"/>
                            <ColumnDefinition Width="0.35*"/>
                            <ColumnDefinition Width="0.1*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="#"/>

                        <TextBlock Grid.Column="1"
                                   Text="X"/>

                        <TextBlock Grid.Column="2"
                                   Text="Y"/>
                    </Grid>
                </Border>

                <ListBox Grid.Row="1"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         Style="{StaticResource Local.Styles.ListBox}"
                         ItemContainerStyle="{StaticResource Local.Styles.ListBoxItem}"
                         ItemTemplate="{StaticResource Local.Templates.ListBoxItem}"
                         ItemsSource="{Binding Points}"/>

            </Grid>
        </Border>

    </Grid>
    
</UserControl>
